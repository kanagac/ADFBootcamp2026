{
	"name": "dataflow4",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "customers"
				},
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "products"
				},
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "order"
				},
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "payment"
				},
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "orderitems"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_sql",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "select4"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "join5"
				},
				{
					"name": "join6"
				},
				{
					"name": "join7"
				},
				{
					"name": "select5"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as integer,",
				"          customer_name as string,",
				"          email as string,",
				"          country as string,",
				"          created_date as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> customers",
				"source(output(",
				"          product_id as integer,",
				"          product_name as string,",
				"          category as string,",
				"          unit_price as decimal(10,3)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> products",
				"source(output(",
				"          order_id as integer,",
				"          customer_id as integer,",
				"          order_date as string,",
				"          order_status as string,",
				"          order_amount as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> order",
				"source(output(",
				"          payment_id as integer,",
				"          order_id as integer,",
				"          payment_mode as string,",
				"          payment_status as string,",
				"          payment_date as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> payment",
				"source(output(",
				"          order_item_id as string,",
				"          order_id as integer,",
				"          product_id as integer,",
				"          quantity as string,",
				"          item_amount as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> orderitems",
				"orderitems, products join(orderitems@product_id == products@product_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"order, orderitems join(order@order_id == orderitems@order_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"payment, orderitems join(payment@order_id == orderitems@order_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"customers, order join(customers@customer_id == order@customer_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join1 select(mapColumn(",
				"          order_item_id,",
				"          order_id,",
				"          product_id = orderitems@product_id,",
				"          quantity,",
				"          item_amount,",
				"          product_id = products@product_id,",
				"          product_name,",
				"          category,",
				"          unit_price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"join3 select(mapColumn(",
				"          payment_id,",
				"          order_id = payment@order_id,",
				"          payment_mode,",
				"          payment_status,",
				"          payment_date,",
				"          order_item_id,",
				"          order_id = orderitems@order_id,",
				"          product_id,",
				"          quantity,",
				"          item_amount",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"join2 select(mapColumn(",
				"          order_id = order@order_id,",
				"          customer_id,",
				"          order_date,",
				"          order_status,",
				"          order_amount,",
				"          order_item_id,",
				"          order_id = orderitems@order_id,",
				"          product_id,",
				"          quantity,",
				"          item_amount",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"join4 select(mapColumn(",
				"          customer_id = customers@customer_id,",
				"          customer_name,",
				"          email,",
				"          country,",
				"          created_date,",
				"          order_id,",
				"          customer_id = order@customer_id,",
				"          order_date,",
				"          order_status,",
				"          order_amount",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"select4 derive(contact = concat(customer_name,'-',email)) ~> derivedColumn2",
				"derivedColumn2, select3 join(select4@order_id == select3@order_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join5",
				"select2, select1 join(select2@order_id == select1@order_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join6",
				"join5, join6 join(select4@order_id == select2@order_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join7",
				"join7 select(mapColumn(",
				"          customer_name,",
				"          email,",
				"          country,",
				"          order_date = select4@order_date,",
				"          order_status = select4@order_status,",
				"          order_amount = select4@order_amount,",
				"          contact,",
				"          payment_mode,",
				"          payment_status,",
				"          payment_date,",
				"          item_amount = select2@item_amount,",
				"          product_name,",
				"          category,",
				"          unit_price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"select5 filter(ERROR_FUNCTION('')) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          customer_name,",
				"          email,",
				"          country,",
				"          order_date,",
				"          order_status,",
				"          order_amount,",
				"          contact,",
				"          payment_mode,",
				"          payment_status,",
				"          payment_date,",
				"          item_amount,",
				"          product_name,",
				"          category,",
				"          unit_price",
				"     )) ~> sink1"
			]
		}
	}
}
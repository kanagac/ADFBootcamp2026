{
	"name": "Customers",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_COMMON",
						"type": "DatasetReference"
					},
					"name": "sourceCustomers"
				},
				{
					"dataset": {
						"referenceName": "DelimitedText4",
						"type": "DatasetReference"
					},
					"name": "targetscd1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_COMMON",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_COMMON",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "processed"
				},
				{
					"name": "split1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "loading"
				},
				{
					"name": "join3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Customer_ID as integer,",
				"          Customer_key as integer,",
				"          Company_Name as string,",
				"          Delete_Flg as string,",
				"          Create_Date as timestamp,",
				"          Date_Last_Modified as timestamp,",
				"          Created_By as string,",
				"          Created_Timestamp as timestamp,",
				"          Last_Updated_By as string,",
				"          Last_Update_Timestamp as binary,",
				"          Active_Flag as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourceCustomers",
				"source(output(",
				"          Customer_Key as integer,",
				"          Customer_Id as integer,",
				"          Company_Name as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> targetscd1",
				"loading derive(Delete_Flg = iif(Active_Flag == 'Y', 'Y', 'N'),",
				"          Active_Flag = iif(currentTimestamp() <= Last_Update_Timestamp,    'Y',    'N')) ~> processed",
				"processed split(isNull(Company_Name),",
				"     disjoint: false) ~> split1@(NEW, CHANGED)",
				"split1@CHANGED alterRow(updateIf(true())) ~> alterRow1",
				"join3 derive(Customer_Key = sourceCustomers@Customer_key,",
				"          Delete_Flg = 'N',",
				"          Active_Flag = 'Y',",
				"          Created_By = 'ADF',",
				"          Created_Timestamp = currentTimestamp(),",
				"          Last_Updated_By = 'ADF',",
				"          Last_Update_Timestamp = currentTimestamp(),",
				"          Company_Name = sourceCustomers@Company_Name) ~> loading",
				"sourceCustomers, targetscd1 join(sourceCustomers@Customer_key == targetscd1@Customer_Key,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"split1@NEW sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Customer_Key = split1@NEW@Customer_Key,",
				"          Customer_Id = split1@NEW@Customer_Id,",
				"          Company_Name = split1@NEW@Company_Name,",
				"          Delete_Flg = split1@NEW@Delete_Flg,",
				"          Active_Flag = split1@NEW@Active_Flag,",
				"          Created_By = split1@NEW@Created_By,",
				"          Created_Timestamp = split1@NEW@Created_Timestamp,",
				"          Last_Updated_By = split1@NEW@Last_Updated_By,",
				"          Last_Update_Timestamp = split1@NEW@Last_Update_Timestamp,",
				"          Customer_ID = split1@NEW@Customer_ID,",
				"          Customer_key = split1@NEW@Customer_key,",
				"          Company_Name = split1@NEW@Company_Name,",
				"          Delete_Flg = split1@NEW@Delete_Flg,",
				"          Create_Date,",
				"          Date_Last_Modified,",
				"          Created_By = split1@NEW@Created_By,",
				"          Created_Timestamp = split1@NEW@Created_Timestamp,",
				"          Last_Updated_By = split1@NEW@Last_Updated_By,",
				"          Last_Update_Timestamp = split1@NEW@Last_Update_Timestamp,",
				"          Active_Flag = split1@NEW@Active_Flag",
				"     )) ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2"
			]
		}
	}
}
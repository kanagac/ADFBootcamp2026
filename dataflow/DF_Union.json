{
	"name": "DF_Union",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_CSV",
						"type": "DatasetReference"
					},
					"name": "employeeIndia"
				},
				{
					"dataset": {
						"referenceName": "DS_CSV",
						"type": "DatasetReference"
					},
					"name": "EmployeeUSA"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Folder",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmpID as short,",
				"          EmployeeName as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> employeeIndia",
				"source(output(",
				"          EmpID as short,",
				"          EmployeeName as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> EmployeeUSA",
				"employeeIndia, EmployeeUSA union(byName: true)~> union1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          StoreId as string,",
				"          StoreName as string,",
				"          City as string,",
				"          Region as string,",
				"          Latitude as string,",
				"          Longitude as string",
				"     ),",
				"     partitionFileNames:['Employees_union.csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}
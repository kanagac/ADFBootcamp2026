{
	"name": "DIM_TITLES",
	"properties": {
		"folder": {
			"name": "Workshop"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"rejectedDataLinkedService": {
						"referenceName": "LS_AZURE_STORAGE",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          title_id as string,",
				"          title_type as string,",
				"          type as string,",
				"          pub_id as string,",
				"          price as decimal(19,4),",
				"          notes as string,",
				"          pubdate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 filter(year(pubdate) < 2021) ~> filter1",
				"filter1 derive(title_id = concat(\"T\",title_id,\"-001\"),",
				"          title_type = concat(upper(type),\"-\",upper(title_type)),",
				"          type = concat(\"TT\",initCap(type)),",
				"          pub_id = trim(upper(pub_id)),",
				"          price = case(  isNull(price),0,\r",
				"     price < 2, toInteger(price * 0.3),   \r",
				"     toInteger(price * 0.1)),",
				"          notes = iif(isNull(notes), \"Notes not found\", \r",
				"\r",
				"concat(left(notes, 3),right(notes, 2))),",
				"          pubdate = upper(toString(toDate(pubdate), 'yyyy-MMM-dd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          title_id,",
				"          title_type,",
				"          type,",
				"          pub_id,",
				"          price,",
				"          notes,",
				"          pubdate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Title_ID = title_id,",
				"          Title_Desc = title_type,",
				"          Type = type,",
				"          Pub_ID = pub_id,",
				"          Price = price,",
				"          Notes = notes,",
				"          Publish_Date = pubdate",
				"     )) ~> sink1"
			]
		}
	}
}
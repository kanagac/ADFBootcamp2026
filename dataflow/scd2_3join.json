{
	"name": "scd2_3join",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "customer"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "Address"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "Contact"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "tgt"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "exists1"
				},
				{
					"name": "exists2"
				},
				{
					"name": "exists3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as integer,",
				"          name as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> customer",
				"source(output(",
				"          customer_id as integer,",
				"          city as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Address",
				"source(output(",
				"          customer_id as integer,",
				"          phone as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Contact",
				"source(output(",
				"          customer_id as integer,",
				"          name as string,",
				"          city as string,",
				"          phone as string,",
				"          start_date as date,",
				"          end_date as date,",
				"          is_current as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> tgt",
				"customer, Address join(customer@customer_id == Address@customer_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, Contact join(customer@customer_id == Contact@customer_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 derive(hash = md5(customer@customer_id,name,city,phone)) ~> derivedColumn1",
				"tgt derive(hash = md5(customer_id,name,city,phone)) ~> derivedColumn2",
				"derivedColumn1, derivedColumn2 exists(derivedColumn1@hash == derivedColumn2@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists1",
				"derivedColumn2, derivedColumn1 exists(tgt@customer_id == customer@customer_id,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists2",
				"exists2, derivedColumn1 exists(derivedColumn2@hash == derivedColumn1@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists3",
				"exists1 derive(start_date = currentDate(),",
				"          end_date = toDate(null()),",
				"          is_current = 1) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          customer_id = customer@customer_id,",
				"          name,",
				"          city,",
				"          phone,",
				"          start_date,",
				"          end_date,",
				"          is_current",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"exists3 derive(end_date = currentDate(),",
				"          is_current = 0) ~> derivedColumn4",
				"derivedColumn4 alterRow(updateIf(1==1)) ~> alterRow1",
				"alterRow1 select(mapColumn(",
				"          customer_id,",
				"          name,",
				"          tgt_city = city,",
				"          phone,",
				"          start_date,",
				"          end_date,",
				"          is_current",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          customer_id,",
				"          name,",
				"          city,",
				"          phone,",
				"          start_date,",
				"          end_date,",
				"          is_current",
				"     )) ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          customer_id,",
				"          name,",
				"          city = tgt_city,",
				"          phone,",
				"          start_date,",
				"          end_date,",
				"          is_current",
				"     )) ~> sink2"
			]
		}
	}
}
{
	"name": "DF_ETL",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "join1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as string,",
				"          name as string,",
				"          salary as string,",
				"          last_modified as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          id as integer,",
				"          name as string,",
				"          salary as integer,",
				"          start_date as timestamp,",
				"          end_date as timestamp,",
				"          is_current as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1 derive(id_clean = iif(isNull(id), -1, toInteger(id)),",
				"          name_clean = iif(isNull(name) || trim(name) == '','UNKNOWN',trim(name)),",
				"          salary_clean = iif(isNull(toInteger(salary)),0,toInteger(salary))) ~> derivedColumn1",
				"source2 filter(is_current == true()) ~> filter1",
				"derivedColumn1, filter1 join(id_clean == source2@id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1"
			]
		}
	}
}
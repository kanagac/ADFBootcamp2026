{
	"name": "SCD2_Stores2",
	"properties": {
		"folder": {
			"name": "SCD"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "AuthorsSource"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "AuthorsTarget"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "UpdateSink"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "InsertSink"
				}
			],
			"transformations": [
				{
					"name": "AuthorDC"
				},
				{
					"name": "AuhtorsSelect"
				},
				{
					"name": "StoresJoin"
				},
				{
					"name": "UpdateFilter"
				},
				{
					"name": "InsertFilter"
				},
				{
					"name": "UpdateUpdate"
				},
				{
					"name": "UpdateColumnSelection"
				},
				{
					"name": "UpdateAlterRow"
				},
				{
					"name": "InsertColumnsSelection"
				},
				{
					"name": "InsertUpdate"
				}
			],
			"scriptLines": [
				"source(output(",
				"          au_lname as string,",
				"          au_fname as string,",
				"          phone as string,",
				"          address as string,",
				"          city as string,",
				"          state as string,",
				"          zip as string,",
				"          contract as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> AuthorsSource",
				"source(output(",
				"          Author_Name as string,",
				"          Author_Phone as string,",
				"          Author_Address as string,",
				"          Author_city as string,",
				"          Author_State as string,",
				"          Author_zip as string,",
				"          AU_Contract_Status as string,",
				"          Start_date as date,",
				"          End_date as date,",
				"          isActive as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> AuthorsTarget",
				"AuthorsSource derive(Author_Name = concat(left(au_lname,1),' ', au_fname),",
				"          Author_Phone = concat('+91-','(',substring(replace(phone,'-',''), 1, 3),')','-(',substring(replace(phone,'-',''), 4, 3),')-',substring(replace(phone,'-',''), 7, length(replace(phone,'-','')))),",
				"          Author_Address = replace(regexReplace(address, '(0-9)', ''), ' ', ','),",
				"          Author_City = city,",
				"          Author_State = upper(replace(state,' ','')),",
				"          Author_Zip = concat(substring(left(rpad(zip, 6, '0'),6),1,3),' ',substring(left(rpad(zip, 6, '0'),6),4,3)),",
				"          AU_Contract_Status = case(contract=='1', 'Active', 'De-Active')) ~> AuthorDC",
				"AuthorDC select(mapColumn(",
				"          Author_Name,",
				"          Author_Phone,",
				"          Author_Address,",
				"          Author_City,",
				"          Author_State,",
				"          Author_Zip,",
				"          AU_Contract_Status",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> AuhtorsSelect",
				"AuhtorsSelect, AuthorsTarget join(AuhtorsSelect@Author_Phone == AuthorsTarget@Author_Phone,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> StoresJoin",
				"StoresJoin filter(!isNull(AuthorsTarget@Author_Phone) && AuhtorsSelect@Author_City!=AuthorsTarget@Author_city) ~> UpdateFilter",
				"StoresJoin filter(isNull(AuthorsTarget@Author_Phone) || AuhtorsSelect@Author_City!=AuthorsTarget@Author_city) ~> InsertFilter",
				"UpdateColumnSelection derive(End_date = currentDate(),",
				"          isActive = 0) ~> UpdateUpdate",
				"UpdateFilter select(mapColumn(",
				"          Author_Name = AuthorsTarget@Author_Name,",
				"          Author_Phone = AuthorsTarget@Author_Phone,",
				"          Author_Address = AuthorsTarget@Author_Address,",
				"          Tgt_Author_city = AuthorsTarget@Author_city,",
				"          Author_State = AuthorsTarget@Author_State,",
				"          Author_zip = AuthorsTarget@Author_zip,",
				"          AU_Contract_Status = AuthorsTarget@AU_Contract_Status,",
				"          Start_date,",
				"          End_date,",
				"          isActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> UpdateColumnSelection",
				"UpdateUpdate alterRow(updateIf(1==1)) ~> UpdateAlterRow",
				"InsertFilter select(mapColumn(",
				"          Author_Name = AuhtorsSelect@Author_Name,",
				"          Author_Phone = AuhtorsSelect@Author_Phone,",
				"          Author_Address = AuhtorsSelect@Author_Address,",
				"          Author_City = AuhtorsSelect@Author_City,",
				"          Author_State = AuhtorsSelect@Author_State,",
				"          Author_Zip = AuhtorsSelect@Author_Zip,",
				"          AU_Contract_Status = AuhtorsSelect@AU_Contract_Status,",
				"          Start_date,",
				"          End_date,",
				"          isActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> InsertColumnsSelection",
				"InsertColumnsSelection derive(Start_date = currentDate(),",
				"          End_date = toDate(null()),",
				"          isActive = 1) ~> InsertUpdate",
				"UpdateAlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['Author_Phone'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Author_Name,",
				"          Author_Phone,",
				"          Author_Address,",
				"          Author_city = Tgt_Author_city,",
				"          Author_State,",
				"          Author_zip,",
				"          AU_Contract_Status,",
				"          Start_date,",
				"          End_date,",
				"          isActive",
				"     )) ~> UpdateSink",
				"InsertUpdate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Author_Name,",
				"          Author_Phone,",
				"          Author_Address,",
				"          Author_City,",
				"          Author_State,",
				"          Author_Zip,",
				"          AU_Contract_Status,",
				"          Start_date,",
				"          End_date,",
				"          isActive",
				"     )) ~> InsertSink"
			]
		}
	}
}
{
	"name": "DF_SCD2_Customer",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Customer_Source",
						"type": "DatasetReference"
					},
					"name": "srcCustomerSCD2"
				},
				{
					"dataset": {
						"referenceName": "DS_Customer_Target_SCD2",
						"type": "DatasetReference"
					},
					"name": "trgCustomerSCD2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Customer_Target_SCD2",
						"type": "DatasetReference"
					},
					"name": "SinkINSERT"
				},
				{
					"dataset": {
						"referenceName": "DS_Customer_Target_SCD2",
						"type": "DatasetReference"
					},
					"name": "SinkUPDATE"
				},
				{
					"dataset": {
						"referenceName": "DS_Customer_Target_SCD2",
						"type": "DatasetReference"
					},
					"name": "SinkINSERT2"
				}
			],
			"transformations": [
				{
					"name": "JoiningCondition"
				},
				{
					"name": "csSplitRecords"
				},
				{
					"name": "arUPDATEOld"
				},
				{
					"name": "drExpiredOld"
				},
				{
					"name": "drNewRecords"
				},
				{
					"name": "drInsertChanged"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcCustomerSCD2",
				"source(output(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> trgCustomerSCD2",
				"srcCustomerSCD2, trgCustomerSCD2 join(srcCustomerSCD2@CustomerID == trgCustomerSCD2@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoiningCondition",
				"JoiningCondition split(isNull(trgCustomerSCD2@CustomerID),",
				"     !isNull(trgCustomerSCD2@CustomerID) \r",
				"&& srcCustomerSCD2@City != trgCustomerSCD2@City,",
				"     !isNull(trgCustomerSCD2@CustomerID) \r",
				"&& srcCustomerSCD2@City != trgCustomerSCD2@City,",
				"     disjoint: false) ~> csSplitRecords@(NewChanges, ChangedRecords, InsertChanged, NOChange)",
				"drExpiredOld alterRow(updateIf(true())) ~> arUPDATEOld",
				"csSplitRecords@ChangedRecords derive(EndDate = currentDate(),",
				"          IsCurrent = 0) ~> drExpiredOld",
				"csSplitRecords@NewChanges derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> drNewRecords",
				"csSplitRecords@InsertChanged derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> drInsertChanged",
				"drNewRecords sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = csSplitRecords@NewChanges@CustomerID,",
				"          Name = csSplitRecords@NewChanges@Name,",
				"          City = csSplitRecords@NewChanges@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> SinkINSERT",
				"arUPDATEOld sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['CustomerSK'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerSK,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> SinkUPDATE",
				"drInsertChanged sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = csSplitRecords@InsertChanged@CustomerID,",
				"          Name = csSplitRecords@InsertChanged@Name,",
				"          City = csSplitRecords@InsertChanged@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> SinkINSERT2"
			]
		}
	}
}
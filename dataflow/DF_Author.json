{
	"name": "DF_Author",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "SourceAuthor"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "TargetAuthor"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "LoadUpset"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "LoadInsert"
				}
			],
			"transformations": [
				{
					"name": "LeftJoin"
				},
				{
					"name": "filter1"
				},
				{
					"name": "filter2"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select2"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          au_lname as string,",
				"          phone as string,",
				"          address as string,",
				"          city as string,",
				"          state as string,",
				"          zip as string,",
				"          contract as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceAuthor",
				"source(output(",
				"          Author_Key as integer,",
				"          Author_Name as string,",
				"          Author_Phone as string,",
				"          Author_Address as string,",
				"          Author_City as string,",
				"          Author_State as string,",
				"          Author_Zip as string,",
				"          AU_Contract_Status as integer,",
				"          Start_Date as timestamp,",
				"          End_Date as timestamp,",
				"          Is_Active as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TargetAuthor",
				"SourceAuthor, TargetAuthor join(phone == Author_Phone,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoin",
				"LeftJoin filter(!isNull(Author_Phone) && city != Author_City) ~> filter1",
				"LeftJoin filter(isNull(Author_Phone) || city != Author_City) ~> filter2",
				"filter2 select(mapColumn(",
				"          au_lname,",
				"          phone,",
				"          address,",
				"          city,",
				"          state,",
				"          zip,",
				"          contract,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(Start_Date = currentDate(),",
				"          End_Date = toDate(null()),",
				"          Is_Active = 1,",
				"          phone = concat(\r",
				"    '+91-(',\r",
				"    substring(phone, 1, 3),\r",
				"    ')-(',\r",
				"    substring(phone, 5, 3),\r",
				"    ')-',\r",
				"    substring(phone, 9, 4)\r",
				"),",
				"          address = replace(regexReplace(address, '[0-9]', ''), ' ', ''),",
				"          state = upper(trim(state)),",
				"          zip = substring(rpad(zip, 6, '0'), 1, 3) + ' ' +\r",
				"substring(rpad(zip, 6, '0'), 4, 3),",
				"          contract = iif(contract == 1, 'Active', 'De-Active')) ~> derivedColumn1",
				"filter1 select(mapColumn(",
				"          Author_Key,",
				"          au_lname,",
				"          phone,",
				"          address,",
				"          tgt_city = city,",
				"          state,",
				"          zip,",
				"          contract,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 derive(End_Date = currentDate(),",
				"          Is_Active = 0,",
				"          phone = concat(\r",
				"    '+91-(',\r",
				"    substring(phone, 1, 3),\r",
				"    ')-(',\r",
				"    substring(phone, 5, 3),\r",
				"    ')-',\r",
				"    substring(phone, 9, 4)\r",
				"),",
				"          address = replace(regexReplace(address, '[0-9]', ''), ' ', ''),",
				"          state = upper(trim(state)),",
				"          zip = substring(rpad(zip, 6, '0'), 1, 3) + ' ' +\r",
				"substring(rpad(zip, 6, '0'), 4, 3),",
				"          contract = iif(contract == 1, 'Active', 'De-Active')) ~> derivedColumn2",
				"derivedColumn2 alterRow(updateIf(true())) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['Author_Key'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Author_Key,",
				"          Author_Name = au_lname,",
				"          Author_Phone = phone,",
				"          Author_Address = address,",
				"          Author_City = tgt_city,",
				"          Author_State = state,",
				"          Author_Zip = zip,",
				"          AU_Contract_Status = contract,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Active",
				"     )) ~> LoadUpset",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Author_Name = au_lname,",
				"          Author_Phone = phone,",
				"          Author_Address = address,",
				"          Author_City = city,",
				"          Author_State = state,",
				"          Author_Zip = zip,",
				"          AU_Contract_Status = contract,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Active",
				"     )) ~> LoadInsert"
			]
		}
	}
}
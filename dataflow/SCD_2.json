{
	"name": "SCD_2",
	"properties": {
		"folder": {
			"name": "Workshop"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "Source"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "Target"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"rejectedDataLinkedService": {
						"referenceName": "LS_AZURE_STORAGE",
						"type": "LinkedServiceReference"
					}
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink2",
					"rejectedDataLinkedService": {
						"referenceName": "LS_AZURE_STORAGE",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "exists1"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				},
				{
					"name": "exists2"
				},
				{
					"name": "exists3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmpID as integer,",
				"          Name as string,",
				"          Department as string,",
				"          Salary as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Source",
				"source(output(",
				"          EmpID as integer,",
				"          Name as string,",
				"          Department as string,",
				"          Salary as decimal(10,2),",
				"          Start_Date as date,",
				"          End_Date as date,",
				"          Is_Current as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Target",
				"Source derive(hash = md5(EmpID,Name,Department,Salary)) ~> derivedColumn1",
				"Target derive(hash = md5(EmpID,Name,Department,Salary)) ~> derivedColumn2",
				"derivedColumn1, derivedColumn2 exists(derivedColumn1@hash == derivedColumn2@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists1",
				"exists1 derive(Start_Date = currentDate(),",
				"          End_Date = toDate(null()),",
				"          Is_Current = 1) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          EmpID,",
				"          Name,",
				"          Department,",
				"          Salary,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Current",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2, derivedColumn1 exists(Target@EmpID == Source@EmpID,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists2",
				"exists2, derivedColumn1 exists(derivedColumn2@hash == derivedColumn1@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists3",
				"exists3 derive(Is_Current = 0) ~> derivedColumn4",
				"derivedColumn4 alterRow(updateIf(1==1)) ~> alterRow1",
				"alterRow1 select(mapColumn(",
				"          EmpID,",
				"          Name,",
				"          Department,",
				"          Salary,",
				"          Start_Date,",
				"          End_Date,",
				"          Is_Current",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['EmpID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2"
			]
		}
	}
}
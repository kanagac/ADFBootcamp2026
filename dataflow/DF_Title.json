{
	"name": "DF_Title",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "SourceTitle"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "LoadTitle"
				}
			],
			"transformations": [
				{
					"name": "Transformation"
				},
				{
					"name": "Filter"
				},
				{
					"name": "Select"
				}
			],
			"scriptLines": [
				"source(output(",
				"          title_id as string,",
				"          title_type as string,",
				"          type as string,",
				"          pub_id as string,",
				"          price as decimal(19,4),",
				"          notes as string,",
				"          pubdate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceTitle",
				"Filter derive(title_id = concat(\r",
				"    'T-',\r",
				"    title_id,\r",
				"    '-001'\r",
				"),",
				"          title_type = iif(\r",
				"    isNull(title_type), \r",
				"\r",
				"    'Title Not Found',\r",
				"    \r",
				"    concat(\r",
				"    upper(trim(type)),\r",
				"    '-',\r",
				"    upper(title_type)\r",
				"    )\r",
				")\r",
				",",
				"          type = iif(\r",
				"    isNull(type), \r",
				"\r",
				"    'Type Not Found',\r",
				"\r",
				"    concat(\r",
				"        'TT-',\r",
				"        initCap(type)\r",
				"    )\r",
				"),",
				"          pub_id = iif(\r",
				"    isNull(pub_id), \r",
				"\r",
				"    'No Publisher ID Found',\r",
				"\r",
				"    trim(upper(pub_id))\r",
				"),",
				"          price = case(\r",
				"    isNull(price), 0,\r",
				"    (price < 2), toInteger(price * 1.3), \r",
				"    toInteger(price * 1.1)\r",
				")\r",
				"\r",
				",",
				"          notes = iif(\r",
				"    isNull(notes), \r",
				"\r",
				"    'Notes Not Found',\r",
				"\r",
				"    substring(notes, 1, 3) +\r",
				"    substring(notes, length(notes) - 1, 2)\r",
				"),",
				"          pubdate = iif(\r",
				"    isNull(pubdate), \r",
				"\r",
				"    '1900-JAN-01',\r",
				"\r",
				"    upper(toString(toDate(pubdate), 'yyyy-MMM-dd'))\r",
				")) ~> Transformation",
				"SourceTitle filter(year(pubdate) < 2021) ~> Filter",
				"Transformation select(mapColumn(",
				"          Title_ID = title_id,",
				"          Title_Desc = title_type,",
				"          Type = type,",
				"          Pub_ID = pub_id,",
				"          Price = price,",
				"          Notes = notes,",
				"          Publish_Date = pubdate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> Select",
				"Select sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Title_ID,",
				"          Title_Desc,",
				"          Type,",
				"          Pub_ID,",
				"          Price,",
				"          Notes,",
				"          Publish_Date",
				"     )) ~> LoadTitle"
			]
		}
	}
}
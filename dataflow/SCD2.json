{
	"name": "SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Customer_Source_SCD1_IN1742",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "Customer_Target_SCD2_IN1742",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Customer_Target_SCD2_IN1742",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "Customer_Target_SCD2_IN1742",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "Customer_Target_SCD2_IN1742",
						"type": "DatasetReference"
					},
					"name": "sink3"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "split1"
				},
				{
					"name": "new"
				},
				{
					"name": "history"
				},
				{
					"name": "updated"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Start_date as timestamp,",
				"          End_Date as timestamp,",
				"          IsCurr as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1, source2 join(source1@CustomerID == source2@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 split(isNull(source1@CustomerID),",
				"     !isNull(source2@CustomerID) && source1@City != source2@City,",
				"     !isNull(source2@CustomerID)  && source1@City != source2@City,",
				"     disjoint: false) ~> split1@(New, Changed, InsertChanged, Nochange)",
				"split1@New derive(Start_date = currentDate(),",
				"          End_Date = toDate(null()),",
				"          IsCurr = 1) ~> new",
				"split1@Changed derive(End_Date = currentDate(),",
				"          IsCurr = 0) ~> history",
				"split1@InsertChanged derive(Start_date = currentDate(),",
				"          End_Date = toDate(null()),",
				"          IsCurr = 1) ~> updated",
				"history alterRow(updateIf(true())) ~> alterRow1",
				"new sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Start_date as timestamp,",
				"          End_Date as timestamp,",
				"          IsCurr as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Start_date as timestamp,",
				"          End_Date as timestamp,",
				"          IsCurr as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2",
				"updated sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Start_date as timestamp,",
				"          End_Date as timestamp,",
				"          IsCurr as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink3"
			]
		}
	}
}
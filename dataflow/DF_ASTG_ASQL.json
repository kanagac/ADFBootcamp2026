{
	"name": "DF_ASTG_ASQL",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "split1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          StoreId as string,",
				"          StoreName as string,",
				"          City as string,",
				"          Region as string,",
				"          Latitude as double,",
				"          Longitude as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false) ~> source1",
				"source1 derive(Full_Store_Name = concat(StoreName,',',Region)) ~> derivedColumn1",
				"derivedColumn1 split(greater(Latitude,90),",
				"     disjoint: false) ~> split1@(latitudeGreater90, latituelesser90)"
			]
		}
	}
}
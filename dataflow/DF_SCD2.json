{
	"name": "DF_SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "SourceCustomer"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "TargetCustomer"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "ExpireTarget"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "NewVersionTarget"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "NewInsertTarget"
				}
			],
			"transformations": [
				{
					"name": "LeftJoin"
				},
				{
					"name": "split1"
				},
				{
					"name": "NewVersionCol"
				},
				{
					"name": "ExpiringCol"
				},
				{
					"name": "UpdateAlter"
				},
				{
					"name": "NewInsertionCol"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceCustomer",
				"source(output(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TargetCustomer",
				"SourceCustomer, TargetCustomer join(SourceCustomer@CustomerID == TargetCustomer@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoin",
				"LeftJoin split(isNull(TargetCustomer@CustomerID),",
				"     !isNull(TargetCustomer@CustomerID) && (SourceCustomer@City != TargetCustomer@City || SourceCustomer@Name != TargetCustomer@Name),",
				"     disjoint: false) ~> split1@(InsertNew, ExpireInsert)",
				"split1@ExpireInsert derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> NewVersionCol",
				"split1@ExpireInsert derive(EndDate = currentDate(),",
				"          IsCurrent = 0) ~> ExpiringCol",
				"ExpiringCol alterRow(updateIf(true())) ~> UpdateAlter",
				"split1@InsertNew derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> NewInsertionCol",
				"UpdateAlter sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CustomerSK'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerSK,",
				"          CustomerID = split1@ExpireInsert@CustomerID,",
				"          Name = split1@ExpireInsert@Name,",
				"          City = split1@ExpireInsert@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> ExpireTarget",
				"NewVersionCol sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = split1@ExpireInsert@CustomerID,",
				"          Name = split1@ExpireInsert@Name,",
				"          City = split1@ExpireInsert@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> NewVersionTarget",
				"NewInsertionCol sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = split1@InsertNew@CustomerID,",
				"          Name = split1@InsertNew@Name,",
				"          City = split1@InsertNew@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> NewInsertTarget"
			]
		}
	}
}
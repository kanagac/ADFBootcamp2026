{
	"name": "DF_SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "SourceCustomer"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_INPUT",
						"type": "DatasetReference"
					},
					"name": "TargetCustomer"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE_OUTPUT",
						"type": "DatasetReference"
					},
					"name": "sink3"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "derivedColumn3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceCustomer",
				"source(output(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TargetCustomer",
				"SourceCustomer, TargetCustomer join(SourceCustomer@CustomerID == TargetCustomer@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 split(isNull(TargetCustomer@CustomerID),",
				"     !isNull(TargetCustomer@CustomerID) && (SourceCustomer@City != TargetCustomer@City),",
				"     disjoint: false) ~> split1@(InsertNew, ExpireInsert)",
				"split1@ExpireInsert derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> derivedColumn1",
				"split1@ExpireInsert derive(EndDate = currentDate(),",
				"          IsCurrent = 0) ~> derivedColumn2",
				"derivedColumn2 alterRow(updateIf(true())) ~> alterRow1",
				"split1@InsertNew derive(StartDate = currentDate(),",
				"          EndDate = toDate(null()),",
				"          IsCurrent = 1) ~> derivedColumn3",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['CustomerSK'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerSK,",
				"          CustomerID = split1@ExpireInsert@CustomerID,",
				"          Name = split1@ExpireInsert@Name,",
				"          City = split1@ExpireInsert@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> sink1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = split1@ExpireInsert@CustomerID,",
				"          Name = split1@ExpireInsert@Name,",
				"          City = split1@ExpireInsert@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> sink2",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = split1@InsertNew@CustomerID,",
				"          Name = split1@InsertNew@Name,",
				"          City = split1@InsertNew@City,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> sink3"
			]
		}
	}
}
{
	"name": "DF_EMP",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference"
					},
					"name": "SRCEmpRaw"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "DerivedFLGNormalize"
				},
				{
					"name": "DerivedCleanParse"
				},
				{
					"name": "DerivedColumnIntelligence"
				}
			],
			"scriptLines": [
				"source(output(",
				"          SRC_EMP_ID as string,",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL_ID as string,",
				"          PHONE_NUMBER as string,",
				"          DATE_OF_JOINING as string,",
				"          DATE_OF_LEAVING as string,",
				"          DEPARTMENT as string,",
				"          DESIGNATION as string,",
				"          CITY as string,",
				"          STATE as string,",
				"          SALARY_RAW as string,",
				"          AGE as string,",
				"          GENDER as string,",
				"          MARITAL_STATUS as string,",
				"          EXPERIENCE_YEARS as string,",
				"          PERFORMANCE_RATING as string,",
				"          CONTRACT_END_DATE as string,",
				"          PROBATION_PERIOD as string,",
				"          LAST_LOGIN_TS as string,",
				"          RECORD_RECEIVED_TS as string,",
				"          FLG as string,",
				"          RECORD_SEQ_NO as string,",
				"          BATCH_ID as string,",
				"          SOURCE_SYSTEM as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRCEmpRaw",
				"SRCEmpRaw derive(FLG = case(\r",
				"    upper(trim(FLG)) == 'I', 'I',\r",
				"    upper(trim(FLG)) == 'INSERT', 'I',\r",
				"    upper(trim(FLG)) == 'N', 'I',\r",
				"    upper(trim(FLG)) == 'NEW', 'I',\r",
				"    upper(trim(FLG)) == 'ADD', 'I',\r",
				"    upper(trim(FLG)) == '1', 'I',\r",
				"    upper(trim(FLG)) == 'U', 'U',\r",
				"    upper(trim(FLG)) == 'UPDATE', 'U',\r",
				"    upper(trim(FLG)) == 'MODIFY', 'U',\r",
				"    upper(trim(FLG)) == 'CHANGE', 'U',\r",
				"    upper(trim(FLG)) == 'M', 'U',\r",
				"    upper(trim(FLG)) == '2', 'U',\r",
				"    'UNKNOWN'\r",
				")) ~> DerivedFLGNormalize",
				"DerivedFLGNormalize derive(FIRST_NAME = initCap(trim(FIRST_NAME)),",
				"          LAST_NAME = initCap(trim(LAST_NAME)),",
				"          FULL_NAME = concat(initCap(trim(FIRST_NAME)), ' ',initCap(trim(LAST_NAME))),",
				"          EMAIL_ID = lower(trim(regexReplace(EMAIL_ID, '\\\\s+', '')))\r",
				",",
				"          PHONE_NUMBER = \r",
				"case(\r",
				"    startsWith(regexReplace(PHONE_NUMBER, '[^0-9]', ''), '91') &&\r",
				"    length(regexReplace(PHONE_NUMBER, '[^0-9]', '')) == 12,\r",
				"    right(regexReplace(PHONE_NUMBER, '[^0-9]', ''), 10),\r",
				"\r",
				"    startsWith(regexReplace(PHONE_NUMBER, '[^0-9]', ''), '0'),\r",
				"    right(regexReplace(PHONE_NUMBER, '[^0-9]', ''), 10),\r",
				"\r",
				"    regexReplace(PHONE_NUMBER, '[^0-9]', '')\r",
				")\r",
				",",
				"          DEPARTMENT = upper(trim(DEPARTMENT)),",
				"          DESIGNATION = initCap(trim(DESIGNATION)),",
				"          CITY = initCap(trim(CITY)),",
				"          STATE = case(\r",
				"  upper(trim(STATE)) == 'MH' || upper(trim(STATE)) == 'MAHARASHTRA', 'Maharashtra',\r",
				"  upper(trim(STATE)) == 'DL' || upper(trim(STATE)) == 'DELHI', 'Delhi',\r",
				"  upper(trim(STATE)) == 'KA' || upper(trim(STATE)) == 'KARNATAKA', 'Karnataka',\r",
				"  upper(trim(STATE)) == 'TN' || upper(trim(STATE)) == 'TAMIL NADU', 'Tamil Nadu',\r",
				"  upper(trim(STATE)) == 'TS' || upper(trim(STATE)) == 'TELANGANA', 'Telangana',\r",
				"  upper(trim(STATE)) == 'GJ' || upper(trim(STATE)) == 'GUJARAT', 'Gujarat',\r",
				"  upper(trim(STATE)) == 'WB' || upper(trim(STATE)) == 'WEST BENGAL', 'West Bengal',\r",
				"  upper(trim(STATE)) == 'RJ' || upper(trim(STATE)) == 'RAJASTHAN', 'Rajasthan',\r",
				"  initCap(trim(STATE))\r",
				"),",
				"          SALARY_CLEAN = toDouble(\r",
				"    regexReplace(\r",
				"        regexReplace(\r",
				"            regexReplace(\r",
				"                regexReplace(\r",
				"                    regexReplace(trim(PHONE_NUMBER), '[₹,\\\\s]|INR|Rs\\\\.|/-', ''),\r",
				"                    'L$',''),\r",
				"                    'INR',''),\r",
				"                    '\\\\.00$',''),\r",
				"                    '[^0-9\\\\.]','')\r",
				"                    ),",
				"          GENDER = case(\r",
				"  upper(trim(GENDER)) == 'M' || upper(trim(GENDER)) == 'MALE' || upper(trim(GENDER)) == '1', 'Male',\r",
				"  upper(trim(GENDER)) == 'F' || upper(trim(GENDER)) == 'FEMALE' || upper(trim(GENDER)) == '2', 'Female',\r",
				"  upper(trim(GENDER)) == 'O' || upper(trim(GENDER)) == 'OTHER' || upper(trim(GENDER)) == 'TRANSGENDER', 'Other',\r",
				"  isNull(GENDER) || trim(GENDER) == '' || upper(trim(GENDER)) == 'NULL' || upper(trim(GENDER)) == 'N/A', 'Unknown',\r",
				"  'Unknown'\r",
				"),",
				"          MARITAL_STATUS = case(\r",
				"  upper(trim(MARITAL_STATUS)) == 'S' || upper(trim(MARITAL_STATUS)) == 'SINGLE' || upper(trim(MARITAL_STATUS)) == 'UNMARRIED', 'Single',\r",
				"  upper(trim(MARITAL_STATUS)) == 'M' || upper(trim(MARITAL_STATUS)) == 'MARRIED', 'Married',\r",
				"  upper(trim(MARITAL_STATUS)) == 'D' || upper(trim(MARITAL_STATUS)) == 'DIVORCED', 'Divorced',\r",
				"  upper(trim(MARITAL_STATUS)) == 'W' || upper(trim(MARITAL_STATUS)) == 'WIDOWED', 'Widowed',\r",
				"  upper(trim(MARITAL_STATUS)) == 'SEPARATED', 'Separated',\r",
				"  'Unknown'\r",
				"),",
				"          DATE_OF_JOINING = coalesce(\r",
				"  toDate(DATE_OF_JOINING, 'dd-MM-yyyy'),\r",
				"  toDate(DATE_OF_JOINING, 'MM/dd/yyyy'),\r",
				"  toDate(DATE_OF_JOINING, 'dd MMM yyyy'),\r",
				"  toDate(DATE_OF_JOINING, 'dd-MMM-yy'),\r",
				"  toDate(DATE_OF_JOINING, 'yyyyMMdd'),\r",
				"  toDate(DATE_OF_JOINING, 'dd.MM.yyyy'),\r",
				"  toDate(DATE_OF_JOINING, 'dd/MM/yy'),\r",
				"  toDate(DATE_OF_JOINING, 'yyyy/MM/dd'),\r",
				"  toDate(DATE_OF_JOINING, 'MMM dd, yyyy'),\r",
				"  toDate(DATE_OF_JOINING, 'dd MMMM yyyy'),\r",
				"  toDate(left(trim(DATE_OF_JOINING), 10), 'yyyy-MM-dd')\r",
				"),",
				"          DATE_OF_LEAVING = case(\r",
				"    isNull(DATE_OF_LEAVING) || upper(trim(DATE_OF_LEAVING)) == 'NULL' || \r",
				"    trim(DATE_OF_LEAVING) == 'NA' || trim(DATE_OF_LEAVING) == '' || upper(trim(DATE_OF_LEAVING)) == 'N/A' || \r",
				"    trim(DATE_OF_LEAVING) == '--' || trim(DATE_OF_LEAVING) == '-' || upper(trim(DATE_OF_LEAVING)) == 'NONE' || \r",
				"    upper(trim(DATE_OF_LEAVING)) == 'NA', toDate(null()),\r",
				"    coalesce(\r",
				"        toDate(DATE_OF_LEAVING, 'dd-MM-yyyy'),\r",
				"        toDate(DATE_OF_LEAVING, 'MM/dd/yyyy'),\r",
				"        toDate(DATE_OF_LEAVING, 'dd MMM yyyy'),\r",
				"        toDate(DATE_OF_LEAVING, 'yyyyMMdd'),\r",
				"        toDate(DATE_OF_LEAVING, 'dd.MM.yyyy'),\r",
				"        toDate(left(trim(DATE_OF_LEAVING),10), 'yyyy-MM-dd')\r",
				"    )\r",
				") ,",
				"          CONTRACT_END_DATE = case(\r",
				"  isNull(CONTRACT_END_DATE) || upper(trim(CONTRACT_END_DATE)) == 'NULL' || upper(trim(CONTRACT_END_DATE)) == 'N/A' || trim(CONTRACT_END_DATE) == '' || trim(CONTRACT_END_DATE) == '--', toDate(null()),\r",
				"  coalesce(\r",
				"    toDate(CONTRACT_END_DATE, 'dd-MM-yyyy'),\r",
				"    toDate(CONTRACT_END_DATE, 'MM/dd/yyyy'),\r",
				"    toDate(CONTRACT_END_DATE, 'dd MMM yyyy'),\r",
				"    toDate(CONTRACT_END_DATE, 'yyyyMMdd'),\r",
				"    toDate(CONTRACT_END_DATE, 'yyyy/MM/dd'),\r",
				"    toDate(left(trim(CONTRACT_END_DATE), 10), 'yyyy-MM-dd')\r",
				"  )\r",
				"),",
				"          LAST_LOGIN_UTC = coalesce(\r",
				"  toTimestamp(LAST_LOGIN_TS, 'yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\''),\r",
				"  toTimestamp(LAST_LOGIN_TS, 'dd-MM-yyyy HH:mm:ss'),\r",
				"  toTimestamp(LAST_LOGIN_TS, 'dd-MM-yyyy HH:mm'),\r",
				"  toTimestamp(LAST_LOGIN_TS, 'MM/dd/yyyy hh:mm a'),\r",
				"  toTimestamp(LAST_LOGIN_TS, 'dd-MMM-yy'),\r",
				"  toTimestamp(LAST_LOGIN_TS, 'dd-MMM-yyyy'),\r",
				"  toTimestamp(left(trim(LAST_LOGIN_TS), 19), 'yyyy-MM-dd HH:mm:ss')\r",
				"),",
				"          RECORD_RECEIVED_UTC = coalesce(\r",
				"  toTimestamp(RECORD_RECEIVED_TS, 'yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\''),\r",
				"  toTimestamp(RECORD_RECEIVED_TS, 'dd-MM-yyyy HH:mm:ss'),\r",
				"  toTimestamp(RECORD_RECEIVED_TS, 'MM/dd/yyyy'),\r",
				"  toTimestamp(RECORD_RECEIVED_TS, 'yyyyMMdd'),\r",
				"  toTimestamp(left(trim(RECORD_RECEIVED_TS), 10), 'yyyy-MM-dd')\r",
				")) ~> DerivedCleanParse",
				"DerivedCleanParse derive(DOJ_YEAR = year(DATE_OF_JOINING),",
				"          DOJ_MONTH = month(DATE_OF_JOINING),",
				"          DOJ_MONTH_NAME = case(\r",
				"  month(DATE_OF_JOINING) == 1, 'January',\r",
				"  month(DATE_OF_JOINING) == 2, 'February',\r",
				"  month(DATE_OF_JOINING) == 3, 'March',\r",
				"  month(DATE_OF_JOINING) == 4, 'April',\r",
				"  month(DATE_OF_JOINING) == 5, 'May',\r",
				"  month(DATE_OF_JOINING) == 6, 'June',\r",
				"  month(DATE_OF_JOINING) == 7, 'July',\r",
				"  month(DATE_OF_JOINING) == 8, 'August',\r",
				"  month(DATE_OF_JOINING) == 9, 'September',\r",
				"  month(DATE_OF_JOINING) == 10, 'October',\r",
				"  month(DATE_OF_JOINING) == 11, 'November',\r",
				"  month(DATE_OF_JOINING) == 12, 'December',\r",
				"  'Unknown'\r",
				")\r",
				",",
				"          DOJ_QUARTER = concat('Q', toString(toInteger(ceil(toFloat(month(DATE_OF_JOINING))/3))),'-',toString(year(DATE_OF_JOINING))),",
				"          DOJ_DAY_OF_WEEK = case(\r",
				"  dayOfWeek(DATE_OF_JOINING) == 1, 'Sunday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 2, 'Monday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 3, 'Tuesday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 4, 'Wednesday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 5, 'Thursday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 6, 'Friday',\r",
				"  dayOfWeek(DATE_OF_JOINING) == 7, 'Saturday',\r",
				"  'Unknown'\r",
				"),",
				"          DOJ_FIN_YEAR = case(\r",
				"  month(DATE_OF_JOINING) >= 4,\r",
				"  concat('FY', toString(year(DATE_OF_JOINING)), '-', right(toString(year(DATE_OF_JOINING) + 1), 2)),\r",
				"  concat('FY', toString(year(DATE_OF_JOINING) - 1), '-', right(toString(year(DATE_OF_JOINING)), 2))\r",
				"),",
				"          DOJ_WEEK_OF_YEAR = weekOfYear(DATE_OF_JOINING),",
				"          IS_WEEKEND_JOIN = iif(dayOfWeek(DATE_OF_JOINING) == 1 || dayOfWeek(DATE_OF_JOINING) == 7, 'Yes', 'No')) ~> DerivedColumnIntelligence"
			]
		}
	}
}
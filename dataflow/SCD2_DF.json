{
	"name": "SCD2_DF",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "DS_SCD2_Customers_Target",
						"type": "DatasetReference"
					},
					"name": "target"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SCD2_Customers_Target",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_SCD2_Customers_Target",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "DS_SCD2_Customers_Target",
						"type": "DatasetReference"
					},
					"name": "sink3"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "select2"
				},
				{
					"name": "split1"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "select4"
				},
				{
					"name": "select5"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "alterRow3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          CustomerSK as integer,",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsCurrent as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> target",
				"source1 select(mapColumn(",
				"          CustomerID,",
				"          Name,",
				"          City",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(SourceHash = md5(Name,City)) ~> derivedColumn1",
				"target filter(IsCurrent==true()) ~> filter1",
				"filter1 derive(TargetHash = md5(Name,City)) ~> derivedColumn2",
				"split1@newinsert derive(StartDate = currentDate(),",
				"          IsCurrent = true()) ~> derivedColumn3",
				"derivedColumn3 alterRow(insertIf(1==1)) ~> alterRow1",
				"derivedColumn1, select2 lookup(CustomerID == trg_CustomerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"derivedColumn2 select(mapColumn(",
				"          trg_CustomerID = CustomerID,",
				"          trg_StartDate = StartDate,",
				"          trg_EndDate = EndDate,",
				"          trg_IsCurrent = IsCurrent,",
				"          trg_TargetHash = TargetHash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"lookup1 split(isNull(trg_CustomerID),",
				"     CustomerID==trg_CustomerID&&(SourceHash!=trg_TargetHash),",
				"     disjoint: false) ~> split1@(newinsert, existing)",
				"split1@existing select(mapColumn(",
				"          trg_CustomerID,",
				"          trg_StartDate,",
				"          trg_EndDate,",
				"          trg_IsCurrent,",
				"          trg_TargetHash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select3 derive(trg_EndDate = currentDate(),",
				"          trg_IsCurrent = false()) ~> derivedColumn4",
				"select4 alterRow(updateIf(true())) ~> alterRow2",
				"derivedColumn4 select(mapColumn(",
				"          CustomerID = trg_CustomerID,",
				"          StartDate = trg_StartDate,",
				"          EndDate = trg_EndDate,",
				"          IsCurrent = trg_IsCurrent,",
				"          TargetHash = trg_TargetHash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"split1@existing select(mapColumn(",
				"          CustomerID,",
				"          Name,",
				"          City",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"select5 derive(StartDate = currentDate(),",
				"          IsCurrent = true()) ~> derivedColumn5",
				"derivedColumn5 alterRow(insertIf(true())) ~> alterRow3",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID,",
				"          Name,",
				"          City,",
				"          StartDate,",
				"          IsCurrent",
				"     )) ~> sink1",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['CustomerID','StartDate'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID,",
				"          StartDate,",
				"          EndDate,",
				"          IsCurrent",
				"     )) ~> sink2",
				"alterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 3,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID,",
				"          Name,",
				"          City,",
				"          StartDate,",
				"          IsCurrent",
				"     )) ~> sink3"
			]
		}
	}
}
{
	"name": "DF_SCD_1_II",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "SourceCustomer"
				},
				{
					"name": "TargetCustomer"
				}
			],
			"sinks": [
				{
					"name": "InsertLoad"
				},
				{
					"name": "UpdateLoad"
				}
			],
			"transformations": [
				{
					"name": "LeftJoin"
				},
				{
					"name": "split1"
				},
				{
					"name": "AlterUpdate"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerId as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false) ~> SourceCustomer",
				"source(output(",
				"          CustomerId as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false) ~> TargetCustomer",
				"SourceCustomer, TargetCustomer join(SourceCustomer@CustomerId == TargetCustomer@CustomerId,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoin",
				"LeftJoin split(isNull(TargetCustomer@CustomerId),",
				"     !isNull(TargetCustomer@CustomerId) && SourceCustomer@City != TargetCustomer@City,",
				"     disjoint: false) ~> split1@(Insert, Update)",
				"split1@Update alterRow(updateIf(true())) ~> AlterUpdate",
				"split1@Insert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          CustomerId = split1@Insert@CustomerId,",
				"          Name = split1@Insert@Name,",
				"          City = split1@Insert@City,",
				"          CustomerId = split1@Insert@CustomerId,",
				"          Name = split1@Insert@Name,",
				"          City = split1@Insert@City",
				"     ),",
				"     format: 'table') ~> InsertLoad",
				"AlterUpdate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table') ~> UpdateLoad"
			]
		}
	}
}
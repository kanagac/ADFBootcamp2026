{
	"name": "DF_Day04_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Day04_01",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Day04_01_Sink",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "SalarySplit"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmpID as short,",
				"          EmployeeName as string,",
				"          Department as string,",
				"          Salary as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(Salary_category = iif(Salary >= 80000, \"High\", iif(Salary >= 50000, \"Medium\", \"Low\"))) ~> SalarySplit",
				"SalarySplit sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['employees_salary_categorized'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}
{
	"name": "DF_title",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DF_Tgt_table",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DF_Tgt_table",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "surrogateKey1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          title_id as string,",
				"          title as string,",
				"          type as string,",
				"          pub_id as string,",
				"          price as string,",
				"          notes as string,",
				"          pubdate as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 keyGenerate(output(Tittle_key as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> surrogateKey1",
				"surrogateKey1 derive(title_id = concat(\"T-\",title_id,\"-001\"),",
				"          Title_desc = concat(upper(type),'-',upper(title)),",
				"          type = concat(\"TT-\",initCap(type)),",
				"          pub_id = trim(upper(pub_id)),",
				"          price = toInteger(price),",
				"          notes = concat(substring(notes, 1, 3),substring(notes, -1, 2)),",
				"          Publish_date = upper(toString(toDate(pubdate),\"yyyy-MMM-dd\"))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          title_id,",
				"          type,",
				"          pub_id,",
				"          price,",
				"          notes,",
				"          Tittle_key,",
				"          Title_desc,",
				"          Publish_date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(price = iif(price>2,price+(price*0.3),price+(price*0.1))) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          Title_ID = title_id,",
				"          Type = type,",
				"          Pub_ID = pub_id,",
				"          Price = price,",
				"          Notes = notes,",
				"          Title_Desc = Title_desc,",
				"          Publish_Date = Publish_date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Title_ID,",
				"          Type,",
				"          Pub_ID,",
				"          Price,",
				"          Notes,",
				"          Title_Desc,",
				"          Publish_Date",
				"     )) ~> sink1"
			]
		}
	}
}
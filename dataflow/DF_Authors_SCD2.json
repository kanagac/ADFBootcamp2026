{
	"name": "DF_Authors_SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "SrcAuthors"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "TgtAuthors"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "join1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "filter2"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          au_lname as string,",
				"          au_fname as string,",
				"          phone as string,",
				"          address as string,",
				"          city as string,",
				"          state as string,",
				"          zip as string,",
				"          contract as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcAuthors",
				"source(output(",
				"          AUTHOR_NAME as string,",
				"          AUTHOR_PHONE as string,",
				"          AUTHOR_ADDRESS as string,",
				"          AUTHOR_CITY as string,",
				"          AUTHOR_STATE as string,",
				"          AUTHOR_ZIP as string,",
				"          AU_CONTRACT_STATUS as boolean,",
				"          START_DATE as date,",
				"          END_DATE as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TgtAuthors",
				"SrcAuthors derive(Author_Name = concat(left('au_lname', 1),'-','au_fname'),",
				"          Author_Phone = concat('+91-(',substring(phone,1,3),')-(',substring(phone, 4, 6),')-',substring(phone,7,length(phone))),",
				"          Author_Address = replace(regexReplace(address, '[0-9]', ' '), ','),",
				"          Author_City = city,",
				"          Author_State = upper(trim(state)),",
				"          Author_Zip = concat(left(rpad(zip,6,'0'), 3),\" \",right(rpad(zip, 6 , '0'), 3)),",
				"          AU_Contract_Status = case(contract == '1', 'Active','De-Active')) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          Author_Name,",
				"          Author_Phone,",
				"          Author_Address,",
				"          Author_City,",
				"          Author_State,",
				"          Author_Zip,",
				"          AU_Contract_Status",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1, TgtAuthors join(select1@Author_Phone == TgtAuthors@AUTHOR_PHONE,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 filter(!isNull(TgtAuthors@AUTHOR_PHONE) && select1@Author_City != TgtAuthors@AUTHOR_CITY) ~> filter1",
				"join1 filter(isNull(TgtAuthors@AUTHOR_PHONE) || select1@Author_City != TgtAuthors@AUTHOR_CITY) ~> filter2",
				"filter2 derive(START_DATE = currentDate(),",
				"          END_DATE = toDate(null())) ~> derivedColumn2",
				"filter1 select(mapColumn(",
				"          Author_Name = select1@Author_Name,",
				"          Author_Phone = select1@Author_Phone,",
				"          Author_Address = select1@Author_Address,",
				"          Tgt_Author_City = TgtAuthors@AUTHOR_CITY,",
				"          Author_State = select1@Author_State,",
				"          Author_Zip = select1@Author_Zip,",
				"          AU_Contract_Status = select1@AU_Contract_Status,",
				"          START_DATE,",
				"          END_DATE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 derive(END_DATE = currentDate()) ~> derivedColumn3",
				"derivedColumn3 alterRow(updateIf(1==1)) ~> alterRow1",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Author_Name,",
				"          Author_Phone,",
				"          Author_Address,",
				"          Author_City = Tgt_Author_City,",
				"          Author_State,",
				"          Author_Zip,",
				"          AU_Contract_Status,",
				"          START_DATE,",
				"          END_DATE",
				"     )) ~> sink2"
			]
		}
	}
}
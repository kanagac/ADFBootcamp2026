			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/DS_SQL_output')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "[parameters('LS_AZURE_SQL')]",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"name": {
						"type": "String"
					}
				},
				"annotations": [],

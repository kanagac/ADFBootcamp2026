{
	"name": "DS_CSV",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_AZURE_STORAGE",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"FileName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@dataset().FileName",
					"type": "Expression"
				},
				"container": "csv"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "EmpID",
				"type": "String"
			},
			{
				"name": "EmployeeName",
				"type": "String"
			},
			{
				"name": "Department",
				"type": "String"
			},
			{
				"name": "Salary",
				"type": "String"
			}
		]
	}
}
{
	"name": "PL_Day_5_Q1_IN1716",
	"properties": {
		"description": "Pipeline to load API data into SQL table",
		"activities": [
			{
				"name": "CP_REST_SQL",
				"description": "copying REST to SQL",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"additionalColumns": [
							{
								"name": "load_timestamp",
								"value": {
									"value": "@utcNow()",
									"type": "Expression"
								}
							},
							{
								"name": "Pipeline_id",
								"value": {
									"value": "@pipeline().RunId",
									"type": "Expression"
								}
							}
						],
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['id']"
								},
								"sink": {
									"name": "user_id",
									"type": "Int64"
								}
							},
							{
								"source": {
									"path": "$['name']"
								},
								"sink": {
									"name": "name",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['email']"
								},
								"sink": {
									"name": "email",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['load_timestamp']"
								},
								"sink": {
									"name": "load_timestamp",
									"type": "DateTime"
								}
							},
							{
								"source": {
									"path": "$['Pipeline_id']"
								},
								"sink": {
									"name": "Pipeline_id",
									"type": "String"
								}
							}
						]
					}
				},
				"inputs": [
					{
						"referenceName": "DS_REST_Generic",
						"type": "DatasetReference",
						"parameters": {
							"URL": {
								"value": "https://jsonplaceholder.typicode.com/users",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference",
						"parameters": {
							"tableName": "tgt_api_users_IN1716"
						}
					}
				]
			}
		],
		"folder": {
			"name": "PL_Day_5_In1716"
		},
		"annotations": []
	}
}
{
	"name": "PL_Duplicate_Check",
	"properties": {
		"activities": [
			{
				"name": "Duplicate_Check",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "SELECT UserID,\n       COUNT(*) AS TGT_Row_Count\nFROM Dim_Subscription_SCD2_TGT_IN1716\nGROUP BY UserID\nHAVING COUNT(*) > 1",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference",
						"parameters": {
							"tableName": "Dim_Subscription_SCD2_TGT_IN1716"
						}
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "Condition",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Duplicate_Check",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@equals(length(activity('Duplicate_Check').output.value),0)",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "Duplicate Found",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "Duplicate_Found",
								"value": "Duplicate Found"
							}
						}
					],
					"ifTrueActivities": [
						{
							"name": "No_Duplicate",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "Duplicate_Not_Found",
								"value": "No Duplicate Occurs"
							}
						}
					]
				}
			}
		],
		"variables": {
			"Duplicate_Not_Found": {
				"type": "String",
				"defaultValue": "No Duplicate"
			},
			"Duplicate_Found": {
				"type": "String",
				"defaultValue": "Duplicate Found"
			}
		},
		"folder": {
			"name": "ETL_Testing"
		},
		"annotations": []
	}
}
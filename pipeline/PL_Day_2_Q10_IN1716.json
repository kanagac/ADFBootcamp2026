							"userProperties": [],
							"typeProperties": {
								"message": "Validation Failed due to invalid records",
								"errorCode": "400"
							}
						}
					]
				}
			}
		],
		"folder": {
			"name": "PL_Day_2_IN1716/Lookup_Activity"

{
	"name": "PL_Day_5_Q3_IN1716",
	"properties": {
		"description": "API to SQL",
		"activities": [
			{
				"name": "CP_JSON_API_SQL",
				"description": "Fetching records from API and moving to SQL",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"QueryParameters.lmit": "RANGE:1:10:1",
							"EndCondition:$.users[0]": "NonExist"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "id"
								},
								"sink": {
									"name": "id",
									"type": "Int64"
								}
							},
							{
								"source": {
									"path": "firstName"
								},
								"sink": {
									"name": "firstName",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "lastName"
								},
								"sink": {
									"name": "lastName",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "maidenName"
								},
								"sink": {
									"name": "maidenName",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "age"
								},
								"sink": {
									"name": "age",
									"type": "Int64"
								}
							},
							{
								"source": {
									"path": "gender"
								},
								"sink": {
									"name": "gender",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "email"
								},
								"sink": {
									"name": "email",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "phone"
								},
								"sink": {
									"name": "phone",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "username"
								},
								"sink": {
									"name": "username",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "password"
								},
								"sink": {
									"name": "password",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "birthDate"
								},
								"sink": {
									"name": "birthDate",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['bloodGroup']"
								},
								"sink": {
									"name": "bloodGroup",
									"type": "String"
								}
							}
						],
						"collectionReference": "$['users']"
					}
				},
				"inputs": [
					{
						"referenceName": "DS_REST_Generic",
						"type": "DatasetReference",
						"parameters": {
							"URL": {
								"value": "https://dummyjson.com/users?limit=10&skip=0",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SQL_GENERIC",
						"type": "DatasetReference",
						"parameters": {
							"tableName": "tgt_api_paginated_IN1716"
						}
					}
				]
			}
		],
		"folder": {
			"name": "PL_Day_5_In1716"
		},
		"annotations": []
	}
}
{
	"name": "PL_Day5Question1",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"additionalColumns": [
							{
								"name": "load_timestamp",
								"value": {
									"value": "@utcNow()",
									"type": "Expression"
								}
							},
							{
								"name": "pipeline_run_id",
								"value": {
									"value": "@pipeline().RunId",
									"type": "Expression"
								}
							}
						],
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"preCopyScript": "truncate table tgt_api_users_IN1720",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['id']"
								},
								"sink": {
									"name": "user_id"
								}
							},
							{
								"source": {
									"path": "$['name']"
								},
								"sink": {
									"name": "name"
								}
							},
							{
								"source": {
									"path": "$['email']"
								},
								"sink": {
									"name": "email"
								}
							},
							{
								"source": {
									"path": "$['load_timestamp']"
								},
								"sink": {
									"name": "load_timestamp"
								}
							},
							{
								"source": {
									"path": "$['pipeline_run_id']"
								},
								"sink": {
									"name": "pipeline_run_id"
								}
							}
						]
					}
				},
				"inputs": [
					{
						"referenceName": "DS_restApi",
						"type": "DatasetReference",
						"parameters": {
							"P_resrApi": " https://jsonplaceholder.typicode.com/users"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference",
						"parameters": {
							"P_tableName": "tgt_api_users_IN1720"
						}
					}
				]
			}
		],
		"folder": {
			"name": "PL_Day5Excercise"
		},
		"annotations": []
	}
}
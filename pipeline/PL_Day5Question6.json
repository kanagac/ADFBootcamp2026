						"parameters": {
							"P_container": "input",
							"P_Directory": "mixedfiles",
							"P_filename": "employees.json"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SQL_TABLE",
						"type": "DatasetReference",
						"parameters": {
							"P_tableName": " tgt_json_IN1720"
						}
					}
				]
			}
		],
		"folder": {
			"name": "PL_Day5Excercise"
		},

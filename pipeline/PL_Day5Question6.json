								"sink": {
									"name": "EmpID"
								}
							},
							{
								"source": {
									"path": "$['EmpName']"
								},
								"sink": {
									"name": "EmpName"
								}
							},
							{
								"source": {
									"path": "$['Department']"
								},
								"sink": {
									"name": "Department"
								}
							},
							{
								"source": {
									"path": "$['Salary']"
								},
								"sink": {
									"name": "Salary"
								}
							}
						]
					}
				},

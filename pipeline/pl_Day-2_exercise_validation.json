			{
				"name": "Specific_filetype",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "size-expression",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@endswith(activity('Speific_file_metadata').output.itemName, '.csv')",
						"type": "Expression"
					}
				}
			}
		],
		"folder": {
			"name": "Exercise-2_IN1717"
		},
		"annotations": []
	}

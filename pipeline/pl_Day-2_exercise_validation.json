								"errorCode": "333"
							}
						}
					],
					"ifTrueActivities": [
						{
							"name": "Speific_file_metadata",
							"type": "GetMetadata",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "DelimitedText1",
									"type": "DatasetReference",
									"parameters": {
										"container": "input",
										"foldername": "sales",
										"filename": "Sales.csv"
									}
								},
								"fieldList": [
									"itemName"
